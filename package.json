{
  "name": "skillchain-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "backend:dev": "python -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "backend:test": "python -m unittest discover -s backend/tests -v",
    "backend:migrate": "python -m alembic -c backend/alembic.ini upgrade head"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
